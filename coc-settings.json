{
    "coc.preferences.extensionUpdateCheck": "daily",
    "git.addedSign.text": "|",
    "git.removedSign.text": "|",
    "git.changeRemovedSign.text": "|",
    "git.topRemovedSign.text": "|",
    "git.changedSign.text": "|",
    "git.addedSign.hlGroup": "DiffAdd",
    "git.changedSign.hlGroup": "DiffChange",
    "git.removedSign.hlGroup": "DiffDelete",
    "git.topRemovedSign.hlGroup": "DiffDelete",
    "git.changeRemovedSign.hlGroup": "DiffChange",
    "suggest.noselect": true,
    "suggest.enablePreselect": false,
    "diagnostic.refreshOnInsertMode": false,
    "coc.preferences.formatOnSaveFiletypes": [
        "json",
        "dart"
    ],
    "rainbow-fart.ffplay": "/usr/bin/ffplay",
    "rainbow-fart.enabled": true,
    "rainbow-fart.locale": [
        "zh"
    ],
    "rainbow-fart.voice-packages": [
        "/home/ph/.config/nvim/voice/jiuweiyaohu",
        "/home/ph/.config/nvim/voice/马保国语音包"
    ],
    "tsserver.npm": "/usr/bin/npm",
    "python.linting.pylintArgs": [
        "--extension-pkg-whitelist=cv2"
    ],
    "cmake.cmakePath": "/usr/bin/cmake",
    "clangd.semanticHighlighting": true,
    "rust-analyzer.serverPath": "/usr/bin/rust-analyzer",
    "languageserver": {
        "lua": {
            "command": "lua-lsp",
            "filetypes": [
                "lua"
            ]
        }
    },
    "rainbow-fart.disable-voice-packages": []
}
